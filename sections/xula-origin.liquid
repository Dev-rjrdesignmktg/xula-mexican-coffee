{{ 'xula-origin.css' | asset_url | stylesheet_tag }}

<section class="xula-origin">
  <div class="page-width">
    <div class="xula-origin__grid">

      <!-- LEFT MEDIA -->
      <div class="xula-origin__media">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1400 }}"
            alt="{{ section.settings.heading | escape }}"
            width="1400"
            height="1600"
            loading="lazy"
          >
        {% endif %}

        {% if section.settings.badge != blank %}
          <div class="xula-origin__badge">{{ section.settings.badge }}</div>
        {% endif %}
      </div>

      <!-- RIGHT CONTENT -->
      <div class="xula-origin__content">

        {% if section.settings.eyebrow != blank %}
          <span class="xula-eyebrow">
            {{ section.settings.eyebrow }}
          </span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="xula-heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.text != blank %}
          <p class="xula-text">
            {{ section.settings.text }}
          </p>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="xula-origin__stats">
            {% for block in section.blocks %}
              <div class="xula-origin__stat" {{ block.shopify_attributes }}>
                <span class="xula-origin__stat-value">{{ block.settings.value }}</span>
                <span class="xula-origin__stat-label">{{ block.settings.label }}</span>
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="xula-btn">
            {{ section.settings.button_label }}
          </a>
        {% endif %}

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Xula Origin",
  "tag": "section",
  "class": "section-xula-origin",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "1,200masl"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Terroir"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Grown in the highlands of Mexico."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "In the volcanic soil of Veracruz and Chiapas, small family farms nurture every cherry by hand, high above the clouds where the air is thin and the harvest is slow."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Meet the Farmers"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "1,200m"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Altitude"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Xula Origin",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": "1,200m",
            "label": "Altitude"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "Bourbon",
            "label": "Variety"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "Nov – Feb",
            "label": "Harvest"
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": "40+",
            "label": "Family farms"
          }
        }
      ]
    }
  ]
}
{% endschema %}
