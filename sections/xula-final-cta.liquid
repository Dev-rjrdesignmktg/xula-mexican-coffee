{{ 'xula-final-cta.css' | asset_url | stylesheet_tag }}
<script src="{{ 'xula-final-cta.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign heading_id = 'xula-final-cta-heading-' | append: section.id
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif
  assign img_alt = section.settings.image_alt | default: section.settings.image.alt | default: section.settings.heading | default: 'XULA specialty coffee ritual'
%}

<section class="xula-cta{% unless has_image %} xula-cta--no-image{% endunless %}" aria-labelledby="{{ heading_id }}">

  <div class="xula-cta__media">
    {% if has_image %}
      <img
        class="xula-cta__image"
        src="{{ section.settings.image | image_url: width: 1600 }}"
        srcset="
          {{ section.settings.image | image_url: width: 480 }} 480w,
          {{ section.settings.image | image_url: width: 768 }} 768w,
          {{ section.settings.image | image_url: width: 1200 }} 1200w,
          {{ section.settings.image | image_url: width: 1600 }} 1600w,
          {{ section.settings.image | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt="{{ img_alt | escape }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="lazy"
        decoding="async"
      >
    {% endif %}
    <div class="xula-cta__overlay" aria-hidden="true"></div>
  </div>

  <div class="page-width">
    <div class="xula-cta__content">

      {% if section.settings.show_urgency and section.settings.urgency_text != blank %}
        <div class="xula-cta__urgency" role="status">
          <svg class="xula-cta__urgency-icon" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M10 2a8 8 0 1 0 0 16 8 8 0 0 0 0-16zm.75 4v4.6l3.9 2.32-.75 1.24-4.65-2.76V6z"/>
          </svg>
          <span
            class="xula-cta__urgency-text"
            data-cta-urgency
            data-cutoff-day="{{ section.settings.urgency_cutoff_day }}"
            data-cutoff-hour="{{ section.settings.urgency_cutoff_hour }}"
            data-label="{{ section.settings.urgency_text | escape }}"
          >
            {{ section.settings.urgency_text }}
          </span>
        </div>
      {% endif %}

      {% if section.settings.eyebrow != blank %}
        <span class="xula-eyebrow xula-cta__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}

      <h2 class="xula-cta__heading" id="{{ heading_id }}">{{ section.settings.heading }}</h2>

      {% if section.settings.text != blank %}
        <p class="xula-cta__text">{{ section.settings.text }}</p>
      {% endif %}

      <div class="xula-cta__actions">
        {% if section.settings.primary_label != blank %}
          <a href="{{ section.settings.primary_link | default: '#' }}" class="xula-btn xula-cta__btn-primary">
            {{ section.settings.primary_label }}
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank %}
          <a href="{{ section.settings.secondary_link | default: '#' }}" class="xula-btn--secondary xula-cta__btn-secondary">
            <span>{{ section.settings.secondary_label }}</span>
            <svg viewBox="0 0 20 20" aria-hidden="true" width="16" height="16">
              <path d="M11.3 4.3 9.9 5.7l3.3 3.3H3v2h10.2l-3.3 3.3 1.4 1.4L17 10z"/>
            </svg>
          </a>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <ul class="xula-cta__trust" role="list">
          {% for block in section.blocks %}
            <li class="xula-cta__trust-item" {{ block.shopify_attributes }}>
              <span class="xula-cta__trust-icon" aria-hidden="true">
                {% case block.settings.icon %}
                  {% when 'shipping' %}
                    <svg viewBox="0 0 24 24"><path d="M3 4h11v9H3zM14 8h4l3 3v2h-7zM6 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm12 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/></svg>
                  {% when 'guarantee' %}
                    <svg viewBox="0 0 24 24"><path d="M12 2 3 6v6c0 5 3.8 9.4 9 10 5.2-.6 9-5 9-10V6l-9-4zm-1.2 13.6-3.4-3.4 1.4-1.4 2 2 4.8-4.8 1.4 1.4z"/></svg>
                  {% when 'secure' %}
                    <svg viewBox="0 0 24 24"><path d="M12 1 4 4v6c0 5.2 3.4 9.8 8 11 4.6-1.2 8-5.8 8-11V4zm0 5a2.5 2.5 0 0 1 1.5 4.5V13a1.5 1.5 0 0 1-3 0v-2.5A2.5 2.5 0 0 1 12 6z"/></svg>
                  {% else %}
                    <svg viewBox="0 0 24 24"><path d="M12 2 2 7v10l10 5 10-5V7z"/></svg>
                {% endcase %}
              </span>
              <span class="xula-cta__trust-label">{{ block.settings.label }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Xula Final CTA",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text override (optional)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Small-Batch. Always Fresh."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Begin Your Ritual Today"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subtext",
      "default": "Specialty-grade Mexican coffee, roasted in small batches and shipped fresh to your door. Your next great cup is one click away."
    },
    {
      "type": "header",
      "content": "Primary action"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Specialty Coffee"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "header",
      "content": "Secondary action (optional)"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "View All Coffees"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Subtle urgency"
    },
    {
      "type": "checkbox",
      "id": "show_urgency",
      "label": "Show urgency message",
      "default": true
    },
    {
      "type": "text",
      "id": "urgency_text",
      "label": "Urgency label",
      "default": "This week's roast batch closes in"
    },
    {
      "type": "select",
      "id": "urgency_cutoff_day",
      "label": "Weekly cutoff day",
      "options": [
        { "value": "monday", "label": "Monday" },
        { "value": "tuesday", "label": "Tuesday" },
        { "value": "wednesday", "label": "Wednesday" },
        { "value": "thursday", "label": "Thursday" },
        { "value": "friday", "label": "Friday" },
        { "value": "saturday", "label": "Saturday" },
        { "value": "sunday", "label": "Sunday" }
      ],
      "default": "sunday"
    },
    {
      "type": "range",
      "id": "urgency_cutoff_hour",
      "label": "Cutoff hour (24-hour clock)",
      "min": 0,
      "max": 23,
      "step": 1,
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "guarantee", "label": "Guarantee" },
            { "value": "secure", "label": "Secure checkout" },
            { "value": "quality", "label": "Quality seal" }
          ],
          "default": "shipping"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Free shipping over $50"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Xula Final CTA",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "shipping", "label": "Free shipping over $50" } },
        { "type": "trust_item", "settings": { "icon": "guarantee", "label": "30-Day Happiness Guarantee" } },
        { "type": "trust_item", "settings": { "icon": "secure", "label": "Secure checkout" } }
      ]
    }
  ]
}
{% endschema %}
