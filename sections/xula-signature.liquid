{{ 'xula-signature.css' | asset_url | stylesheet_tag }}

<section class="xula-signature">
  <div class="page-width">
    <div class="xula-signature__grid">

      <!-- LEFT CONTENT -->
      <div class="xula-signature__content">

        {% if section.settings.eyebrow != blank %}
          <span class="xula-eyebrow">
            {{ section.settings.eyebrow }}
          </span>
        {% endif %}

        <h2 class="xula-heading xula-signature__heading">
          {{ section.settings.heading }}
        </h2>

        <p class="xula-signature__text">
          {{ section.settings.text }}
        </p>

        <div class="xula-signature__actions">
          {% if section.settings.button_label != blank %}
            <a href="{{ section.settings.button_link }}" class="xula-btn">
              {{ section.settings.button_label }}
            </a>
          {% endif %}

          {% if section.settings.secondary_button_label != blank %}
            <a href="{{ section.settings.secondary_button_link }}" class="xula-btn--secondary">
              {{ section.settings.secondary_button_label }}
            </a>
          {% endif %}
        </div>

      </div>

      <!-- RIGHT VISUALS -->
      <div class="xula-signature__visuals">

        {% for block in section.blocks %}
          <article
            class="xula-signature__card xula-signature__card--{{ forloop.index }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.image != blank %}
              <div class="xula-signature__media">
                <img
                  src="{{ block.settings.image | image_url: width: 1400 }}"
                  alt="{{ block.settings.title }}"
                  width="1400"
                  height="350"
                  loading="lazy"
                >
              </div>
            {% endif %}

            <div class="xula-signature__meta">
              <span>{{ block.settings.label }}</span>
              <h3>{{ block.settings.title }}</h3>
            </div>
          </article>
        {% endfor %}

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Xula Signature",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Signature Rituals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for every ritual."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "From your first sip in the morning to your sweetest evening comfort, XULA creates moments worth slowing down for."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button",
      "default": "Shop Coffee"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "ritual",
      "name": "Ritual Card",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Morning Ritual"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Speciality Coffee"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Xula Signature"
    }
  ]
}
{% endschema %}